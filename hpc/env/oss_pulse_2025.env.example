# Copy this file to `hpc/env/oss_pulse_2025.env` on SSH/HPC and edit as needed.

# ----------------------------
# SSH / local filesystem layout
# ----------------------------
export LOCAL_PROJECT_ROOT="${HOME}/oss_pulse"
export PROJECT_CODE_DIR="${LOCAL_PROJECT_ROOT}/project"

export LOCAL_DATA_ROOT="${LOCAL_PROJECT_ROOT}/data"
export LOCAL_SOURCE_DIR="${LOCAL_DATA_ROOT}/source/gharchive/2025"

export LOCAL_OUTPUT_ROOT="${LOCAL_PROJECT_ROOT}/output/gharchive/2025"
export LOCAL_PROFILE_DIR="${LOCAL_OUTPUT_ROOT}/profiling"
export LOCAL_SAMPLE_DIR="${LOCAL_OUTPUT_ROOT}/samples"
export LOCAL_LOG_DIR="${LOCAL_PROJECT_ROOT}/logs/gharchive/2025"
export LOCAL_REPORT_DIR="${LOCAL_PROJECT_ROOT}/reports"

# ----------------------------
# HDFS layout
# ----------------------------
export HDFS_ROOT="/user/${USER}/oss_pulse"
export HDFS_SOURCE_DIR="${HDFS_ROOT}/stage/source/gharchive/2025"
export HDFS_RAW_DIR="${HDFS_ROOT}/stage/raw/gharchive/2025"
export HDFS_CLEAN_STAGE_DIR="${HDFS_ROOT}/stage/cleaned/gharchive/2025"
export HDFS_CLEAN_DIR="${HDFS_ROOT}/cleaned/gharchive/2025"

# ----------------------------
# Spark submission defaults
# ----------------------------
export SPARK_SUBMIT_CMD="spark-submit"
export SPARK_MASTER="yarn"
export SPARK_DEPLOY_MODE="client"

export SPARK_DRIVER_MEMORY="8g"
export SPARK_EXECUTOR_MEMORY="8g"
export SPARK_EXECUTOR_CORES="4"
export SPARK_NUM_EXECUTORS="8"
export SPARK_DRIVER_MAX_RESULT_SIZE="2g"
export SPARK_SQL_SHUFFLE_PARTITIONS="400"
export SPARK_DEFAULT_PARALLELISM="200"
export SPARK_MAX_PARTITION_BYTES="128m"

# ----------------------------
# Download / ingestion settings
# ----------------------------
export YEAR="2025"
export DOWNLOAD_JOBS="4"
export INGEST_WRITE_PARTITIONS="256"
export DELETE_LOCAL_SOURCE_AFTER_MONTH="true"
export DELETE_HDFS_STAGE_AFTER_MONTH="true"
export START_MONTH="1"
export END_MONTH="12"

# Optional: point this to a CSV with a repo_name column to filter cleaned output.
# export SEED_REPO_FILE="${PROJECT_CODE_DIR}/data/seed_repo_list.csv"

# Optional: if your cluster uses a custom Python environment
# export PYSPARK_PYTHON="/path/to/python"
# export PYSPARK_DRIVER_PYTHON="/path/to/python"
